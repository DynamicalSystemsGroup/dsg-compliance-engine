@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix doap: <http://usefulinc.com/ns/doap#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix owl1: <http://www.w3.org/2002/07/owl> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<http://www.w3.org/ns/earl#Assertion> a rdfs:Class,
        owl:Class ;
    rdfs:label "Assertion"@en ;
    rdfs:comment "a statement that embodies the results of a test"@en .

<http://www.w3.org/ns/earl#Assertor> a rdfs:Class,
        owl:Class ;
    rdfs:label "Assertor"@en ;
    rdfs:comment "an entity such as a person, a software tool, an organization, or any other grouping that carries out a test collectively"@en .

<http://www.w3.org/ns/earl#CannotTell> a rdfs:Class,
        owl:Class ;
    rdfs:label "Undetermined"@en ;
    rdfs:comment "the class of outcomes to denote an undetermined outcome"@en ;
    rdfs:subClassOf <http://www.w3.org/ns/earl#OutcomeValue> .

<http://www.w3.org/ns/earl#Fail> a rdfs:Class,
        owl:Class ;
    rdfs:label "Fail"@en ;
    rdfs:comment "the class of outcomes to denote failing a test"@en ;
    rdfs:subClassOf <http://www.w3.org/ns/earl#OutcomeValue> .

<http://www.w3.org/ns/earl#NotApplicable> a rdfs:Class,
        owl:Class ;
    rdfs:label "Not applicable"@en ;
    rdfs:comment "the class of outcomes to denote the test is not applicable"@en ;
    rdfs:subClassOf <http://www.w3.org/ns/earl#OutcomeValue> .

<http://www.w3.org/ns/earl#NotTested> a rdfs:Class,
        owl:Class ;
    rdfs:label "Not tested"@en ;
    rdfs:comment "the class of outcomes to denote the test has not been carried out"@en ;
    rdfs:subClassOf <http://www.w3.org/ns/earl#OutcomeValue> .

<http://www.w3.org/ns/earl#OutcomeValue> a rdfs:Class,
        owl:Class ;
    rdfs:label "Outcome Value"@en ;
    rdfs:comment "a discrete value that describes a resulting condition from carrying out the test"@en .

<http://www.w3.org/ns/earl#Pass> a rdfs:Class,
        owl:Class ;
    rdfs:label "Pass"@en ;
    rdfs:comment "the class of outcomes to denote passing a test"@en ;
    rdfs:subClassOf <http://www.w3.org/ns/earl#OutcomeValue> .

<http://www.w3.org/ns/earl#Software> a rdfs:Class,
        owl:Class ;
    rdfs:label "Software"@en ;
    rdfs:comment "any piece of software such as an authoring tool, browser, or evaluation tool"@en ;
    rdfs:subClassOf doap:Project .

<http://www.w3.org/ns/earl#TestCase> a rdfs:Class,
        owl:Class ;
    rdfs:label "Test Case"@en ;
    rdfs:comment "an atomic test, usually one that is a partial test for a requirement"@en ;
    rdfs:subClassOf <http://www.w3.org/ns/earl#TestCriterion> .

<http://www.w3.org/ns/earl#TestCriterion> a rdfs:Class,
        owl:Class ;
    rdfs:label "Test Criterion"@en ;
    rdfs:comment "a testable statement, usually one that can be passed or failed"@en .

<http://www.w3.org/ns/earl#TestMode> a rdfs:Class,
        owl:Class ;
    rdfs:label "Test Mode"@en ;
    rdfs:comment "describes how a test was carried out"@en .

<http://www.w3.org/ns/earl#TestRequirement> a rdfs:Class,
        owl:Class ;
    rdfs:label "Test Requirement"@en ;
    rdfs:comment "a higher-level requirement that is tested by executing one or more sub-tests"@en ;
    rdfs:subClassOf <http://www.w3.org/ns/earl#TestCriterion> .

<http://www.w3.org/ns/earl#TestResult> a rdfs:Class,
        owl:Class ;
    rdfs:label "Test Result"@en ;
    rdfs:comment "the actual result of performing the test"@en .

<http://www.w3.org/ns/earl#TestSubject> a rdfs:Class,
        owl:Class ;
    rdfs:label "Test Subject"@en ;
    rdfs:comment "the class of things that have been tested against some test criterion"@en .

<http://www.w3.org/ns/earl#> a owl1:Ontology ;
    rdfs:label "Evaluation and Report Language (EARL) 1.0 Schema"@en ;
    rdfs:comment "Formal schema of the Evaluation and Report Language (EARL) 1.0"@en ;
    rdfs:isDefinedBy <http://www.w3.org/TR/EARL10/> ;
    rdfs:seeAlso <http://www.w3.org/TR/Content-in-RDF/>,
        <http://www.w3.org/TR/HTTP-in-RDF/>,
        <http://www.w3.org/TR/Pointers-in-RDF/>,
        <http://www.w3.org/WAI/intro/earl> ;
    owl1:versionInfo "Editor's Working Draft 10 June 2009"@en .

<http://www.w3.org/ns/earl#assertedBy> a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "Asserted By"@en ;
    rdfs:comment "assertor of an assertion"@en ;
    rdfs:domain <http://www.w3.org/ns/earl#Assertion> ;
    rdfs:range <http://www.w3.org/ns/earl#Assertor> .

<http://www.w3.org/ns/earl#automatic> a <http://www.w3.org/ns/earl#TestMode> ;
    dcterms:description "where the test was carried out automatically by the software tool and without any human intervention"@en ;
    dcterms:title "Automatic"@en .

<http://www.w3.org/ns/earl#failed> a <http://www.w3.org/ns/earl#Fail> ;
    dcterms:description "the subject failed the test"@en ;
    dcterms:title "Failed"@en .

<http://www.w3.org/ns/earl#inapplicable> a <http://www.w3.org/ns/earl#NotApplicable> ;
    dcterms:description "the test is not applicable to the subject"@en ;
    dcterms:title "Inapplicable"@en .

<http://www.w3.org/ns/earl#info> a rdf:Property,
        owl:DatatypeProperty ;
    rdfs:label "Info"@en ;
    rdfs:comment "additional warnings or error messages in a human-readable form"@en ;
    rdfs:domain <http://www.w3.org/ns/earl#TestResult> ;
    rdfs:range rdfs:Literal .

<http://www.w3.org/ns/earl#mainAssertor> a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "Main Assertor"@en ;
    rdfs:comment "assertor that is primarily responsible for performing the test"@en ;
    rdfs:domain <http://www.w3.org/ns/earl#Assertor> ;
    rdfs:range <http://www.w3.org/ns/earl#Assertor> ;
    rdfs:subPropertyOf <http://xmlns.com/foaf/spec/#term_member> .

<http://www.w3.org/ns/earl#manual> a <http://www.w3.org/ns/earl#TestMode> ;
    dcterms:description "where the test was carried out by human evaluators"@en ;
    dcterms:title "Manual"@en .

<http://www.w3.org/ns/earl#mode> a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "Mode"@en ;
    rdfs:comment "mode in which the test was performed"@en ;
    rdfs:domain <http://www.w3.org/ns/earl#Assertion> ;
    rdfs:range <http://www.w3.org/ns/earl#TestMode> .

<http://www.w3.org/ns/earl#outcome> a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "Outcome"@en ;
    rdfs:comment "outcome of performing the test"@en ;
    rdfs:domain <http://www.w3.org/ns/earl#TestResult> ;
    rdfs:range <http://www.w3.org/ns/earl#OutcomeValue> .

<http://www.w3.org/ns/earl#passed> a <http://www.w3.org/ns/earl#Pass> ;
    dcterms:description "the subject passed the test"@en ;
    dcterms:title "Passed"@en .

<http://www.w3.org/ns/earl#pointer> a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "Pointer"@en ;
    rdfs:comment "location within a test subject that are most relevant to a test result"@en ;
    rdfs:domain <http://www.w3.org/ns/TestResult> ;
    rdfs:range <http://www.w3.org/2009/pointers#Pointer> .

<http://www.w3.org/ns/earl#result> a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "Result"@en ;
    rdfs:comment "result of an assertion"@en ;
    rdfs:domain <http://www.w3.org/ns/earl#Assertion> ;
    rdfs:range <http://www.w3.org/ns/earl#TestResult> .

<http://www.w3.org/ns/earl#semiAuto> a <http://www.w3.org/ns/earl#TestMode> ;
    dcterms:description "where the test was partially carried out by software tools, but where human input or judgment was still required to decide or help decide the outcome of the test"@en ;
    dcterms:title "Semi-Automatic"@en .

<http://www.w3.org/ns/earl#subject> a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "Subject"@en ;
    rdfs:comment "test subject of an assertion"@en ;
    rdfs:domain <http://www.w3.org/ns/earl#Assertion> ;
    rdfs:range <http://www.w3.org/ns/earl#TestSubject> .

<http://www.w3.org/ns/earl#test> a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "Test"@en ;
    rdfs:comment "test criterion of an assertion"@en ;
    rdfs:domain <http://www.w3.org/ns/earl#Assertion> ;
    rdfs:range <http://www.w3.org/ns/earl#TestCriterion> .

<http://www.w3.org/ns/earl#undisclosed> a <http://www.w3.org/ns/earl#TestMode> ;
    dcterms:description "where the exact testing process is undisclosed"@en ;
    dcterms:title "Undisclosed"@en .

<http://www.w3.org/ns/earl#unknownMode> a <http://www.w3.org/ns/earl#TestMode> ;
    dcterms:description "where the testing process is unknown or undetermined"@en ;
    dcterms:title "Unknown"@en .

<http://www.w3.org/ns/earl#untested> a <http://www.w3.org/ns/earl#NotTested> ;
    dcterms:description "the test has not been carried out"@en ;
    dcterms:title "Untested"@en .

