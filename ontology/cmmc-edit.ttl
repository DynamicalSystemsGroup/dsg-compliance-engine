# CMMC integration ontology — SOURCE (hand-edited). Build → cmmc.ttl.
# Generated from reference/control-catalog.md (Document 1): all 110
# NIST SP 800-171 Rev.2 controls encoded as cmmc:Control individuals with
# SPRS weights (32 CFR 170.24) and POA&M eligibility (32 CFR 170.21).
# No novel epistemic vocabulary: cmmc:Control is a SysMLv2 requirement;
# status reuses the EARL lattice.

@prefix cmmc:  <http://dynamicalsystems.group/ontology/cmmc#> .
@prefix ce:    <http://dynamicalsystems.group/compliance-engine/> .
@prefix sysml: <https://www.omg.org/spec/SysML/2.0/> .
@prefix earl:  <http://www.w3.org/ns/earl#> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .

#################################################################
# TBox — thin integration layer over established standards
#################################################################

cmmc:Control a owl:Class ;
    rdfs:subClassOf sysml:RequirementDefinition ;
    rdfs:label "CMMC control (a requirement to be attested MET)" .

cmmc:Family a owl:Class ;
    rdfs:label "NIST 800-171 control family (AC, AU, IA, SC, ...)" .

cmmc:AssessmentMethod a owl:Class ;
    rdfs:label "NIST SP 800-171A assessment method (Examine/Interview/Test)" .

# --- data properties mirroring Document 1's columns ---
cmmc:controlId         a owl:DatatypeProperty ; rdfs:range xsd:string .
cmmc:text              a owl:DatatypeProperty ; rdfs:range xsd:string .   # verbatim NIST statement
cmmc:weight            a owl:DatatypeProperty ; rdfs:range xsd:integer .  # 1 | 3 | 5 (max for variable)
cmmc:poamEligible      a owl:DatatypeProperty ; rdfs:range xsd:boolean .
cmmc:nonDeferrable     a owl:DatatypeProperty ; rdfs:range xsd:boolean .
cmmc:variableWeight    a owl:DatatypeProperty ; rdfs:range xsd:boolean .  # weight varies by implementation
cmmc:weightIfPartial   a owl:DatatypeProperty ; rdfs:range xsd:integer .  # reduced score for variable controls
cmmc:inherited         a owl:DatatypeProperty ; rdfs:range xsd:boolean .  # CSP-inherited (MET-when-attested)
cmmc:family            a owl:ObjectProperty   ; rdfs:range cmmc:Family .
cmmc:assessmentMethod  a owl:ObjectProperty   ; rdfs:range cmmc:AssessmentMethod .
cmmc:poamItem          a owl:ObjectProperty .   # link to a POA&M entry (legal only if weight = 1)
cmmc:overrideJustification a owl:DatatypeProperty ; rdfs:range xsd:string .  # R13 contradiction override

cmmc:Examine   a cmmc:AssessmentMethod .
cmmc:Interview a cmmc:AssessmentMethod .
cmmc:Test      a cmmc:AssessmentMethod .

# families

cmmc:AC a cmmc:Family ; rdfs:label "Access Control" .
cmmc:AT a cmmc:Family ; rdfs:label "Awareness and Training" .
cmmc:AU a cmmc:Family ; rdfs:label "Audit and Accountability" .
cmmc:CM a cmmc:Family ; rdfs:label "Configuration Management" .
cmmc:IA a cmmc:Family ; rdfs:label "Identification and Authentication" .
cmmc:IR a cmmc:Family ; rdfs:label "Incident Response" .
cmmc:MA a cmmc:Family ; rdfs:label "Maintenance" .
cmmc:MP a cmmc:Family ; rdfs:label "Media Protection" .
cmmc:PS a cmmc:Family ; rdfs:label "Personnel Security" .
cmmc:PE a cmmc:Family ; rdfs:label "Physical Protection" .
cmmc:RA a cmmc:Family ; rdfs:label "Risk Assessment" .
cmmc:CA a cmmc:Family ; rdfs:label "Security Assessment" .
cmmc:SC a cmmc:Family ; rdfs:label "System and Communications Protection" .
cmmc:SI a cmmc:Family ; rdfs:label "System and Information Integrity" .

#################################################################
# ABox — the 110 controls (Document 1). weight histogram:
#   {5: 42, 3: 14, 1: 52, variable: 2}
#################################################################

