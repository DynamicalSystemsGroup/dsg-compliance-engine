ce:POL_MP_Media a sysml:PartUsage ;
    rdfs:label "Media protection: labeling, storage, sanitization (NIST SP 800-88)" ;
    sysml:ownedRelationship [
        a sysml:SatisfyRequirementUsage ;
        sysml:satisfyingElement ce:POL_MP_Media ;
