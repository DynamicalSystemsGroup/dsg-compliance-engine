# Tier 1 (IL4 / CMMC L2) cloud topology — module ↔ control allocation.
#
# HAND-AUTHORED AND MACHINE-UNVERIFIED. This mapping asserts which Tier 1
# buildout resource satisfies which NIST SP 800-171 control. Its correctness
# is NOT established by any oracle in this repo — it rests on the deferred
# mapping-review sign-off (a human control-engineering review of this table)
# plus the Gate 2 Affirming Official attestation. Treat every claim here as a
# proposition to be verified, not a fact.
#
# Each buildout resource is a sysml:PartUsage (the same satisfy-edge pattern as
# ADCS-lifecycle-demo/structural/satellite.ttl — not a new class) carrying:
#   - a sysml:SatisfyRequirementUsage edge (satisfyingElement → this module,
#     satisfiedRequirement → the cmmc:Control), and
#   - cmmc:controlsSatisfied  (object property, module → each control it claims), and
#   - cmmc:verificationMethod (WHICH oracle/live-test confirms the claim):
#       * an IRI  ce:oracle-<slug>  ⇒ MACHINE-verifiable (an oracle/live-test the
#         Factory runs). These feed the proven side of the proven-vs-attested metric.
#       * a LITERAL "inherited:…" / "manual:…" ⇒ NOT machine-verifiable; the claim
#         rests on CSP inheritance (Google CRM) or human attestation.
# Gate 1's "no untestable claim" check requires every claiming module to name a
# verificationMethod; the coverage metric counts controls with no MACHINE method.
#
# Prefixes match ontology/prefixes.py and ontology/cmmc-edit.ttl exactly.

@prefix ce:    <http://dynamicalsystems.group/compliance-engine/> .
@prefix cmmc:  <http://dynamicalsystems.group/ontology/cmmc#> .
@prefix sysml: <https://www.omg.org/spec/SysML/2.0/> .
@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .

ce:Tier1Enclave a sysml:PartDefinition ;
    rdfs:label "Tier 1 IL4 CUI enclave (Workspace Enterprise Plus + GCP Assured Workloads IL4)" ;
    sysml:ownedPart ce:Workspace2SV_CUI_OU ,
                    ce:CMEK_KeyRing ,
                    ce:CUI_Users_Group ,
                    ce:Drive_DLP_Rules ,
                    ce:OrgPolicy_USRegion ,
                    ce:AuditLog_Export ,
                    ce:Disable_NonFedRAMP_Services ,
                    ce:Terraform_Baseline ,
                    ce:Monitoring_Alerting ,
                    ce:CSP_Physical_Inheritance .

#################################################################
# Machine-verifiable modules (verificationMethod is an oracle IRI)
#################################################################

# MFA / 2-Step Verification enforced on the CUI OU.
ce:Workspace2SV_CUI_OU a sysml:PartUsage ;
    rdfs:label "Google Workspace 2-Step Verification (phishing-resistant) enforced on CUI OU" ;
    sysml:ownedRelationship [
        a sysml:SatisfyRequirementUsage ;
        sysml:satisfyingElement ce:Workspace2SV_CUI_OU ;
        sysml:satisfiedRequirement cmmc:IA.L2-3.5.3 , cmmc:IA.L2-3.5.2 , cmmc:IA.L2-3.5.4
    ] ;
    cmmc:controlsSatisfied cmmc:IA.L2-3.5.3 , cmmc:IA.L2-3.5.2 , cmmc:IA.L2-3.5.4 ;
    cmmc:verificationMethod ce:oracle-mfa-2sv-enforced .

# CMEK / Client-Side Encryption key management (FIPS-validated).
ce:CMEK_KeyRing a sysml:PartUsage ;
    rdfs:label "Cloud KMS CMEK + Workspace CSE key management (FIPS-validated crypto)" ;
    sysml:ownedRelationship [
        a sysml:SatisfyRequirementUsage ;
        sysml:satisfyingElement ce:CMEK_KeyRing ;
        sysml:satisfiedRequirement cmmc:SC.L2-3.13.11 , cmmc:SC.L2-3.13.10 , cmmc:SC.L2-3.13.16
    ] ;
    cmmc:controlsSatisfied cmmc:SC.L2-3.13.11 , cmmc:SC.L2-3.13.10 , cmmc:SC.L2-3.13.16 ;
    cmmc:verificationMethod ce:oracle-cmek-fips-keyring .

# IAM groups + least-privilege role bindings for CUI users.
ce:CUI_Users_Group a sysml:PartUsage ;
    rdfs:label "IAM groups + least-privilege role bindings for CUI access" ;
    sysml:ownedRelationship [
        a sysml:SatisfyRequirementUsage ;
        sysml:satisfyingElement ce:CUI_Users_Group ;
        sysml:satisfiedRequirement cmmc:AC.L2-3.1.1 , cmmc:AC.L2-3.1.2 , cmmc:AC.L2-3.1.5
    ] ;
    cmmc:controlsSatisfied cmmc:AC.L2-3.1.1 , cmmc:AC.L2-3.1.2 , cmmc:AC.L2-3.1.5 ;
    cmmc:verificationMethod ce:oracle-iam-least-privilege .

# Drive/Gmail DLP rules controlling CUI flow.
ce:Drive_DLP_Rules a sysml:PartUsage ;
    rdfs:label "Drive + Gmail DLP rules (control the flow of CUI)" ;
    sysml:ownedRelationship [
        a sysml:SatisfyRequirementUsage ;
        sysml:satisfyingElement ce:Drive_DLP_Rules ;
        sysml:satisfiedRequirement cmmc:AC.L2-3.1.3
    ] ;
    cmmc:controlsSatisfied cmmc:AC.L2-3.1.3 ;
    cmmc:verificationMethod ce:oracle-drive-dlp-rules .

# Org Policy: US-only resource locations (data residency).
# ALSO enforces ITAR §120.54 U.S.-person data residency — carried as a
# residency basis, NOT as a cmmc:controlsSatisfied (ITAR-120.54 is not a
# NIST 800-171 control in the catalog).
ce:OrgPolicy_USRegion a sysml:PartUsage ;
    rdfs:label "GCP Org Policy: US-only resource locations + restricted service usage" ;
    sysml:ownedRelationship [
        a sysml:SatisfyRequirementUsage ;
        sysml:satisfyingElement ce:OrgPolicy_USRegion ;
        sysml:satisfiedRequirement cmmc:SC.L2-3.13.1
    ] ;
    cmmc:controlsSatisfied cmmc:SC.L2-3.13.1 ;
    cmmc:verificationMethod ce:oracle-orgpolicy-us-residency ;
    ce:residencyBasis "ITAR-120.54" .

# Workspace + GCP audit log export to retained storage.
ce:AuditLog_Export a sysml:PartUsage ;
    rdfs:label "Workspace + GCP audit log export to retained Cloud Storage bucket" ;
    sysml:ownedRelationship [
        a sysml:SatisfyRequirementUsage ;
        sysml:satisfyingElement ce:AuditLog_Export ;
        sysml:satisfiedRequirement cmmc:AU.L2-3.3.1 , cmmc:AU.L2-3.3.2 , cmmc:AU.L2-3.3.5
    ] ;
    cmmc:controlsSatisfied cmmc:AU.L2-3.3.1 , cmmc:AU.L2-3.3.2 , cmmc:AU.L2-3.3.5 ;
    cmmc:verificationMethod ce:oracle-auditlog-export .

# Disable non-FedRAMP services for the CUI OU (least functionality).
ce:Disable_NonFedRAMP_Services a sysml:PartUsage ;
    rdfs:label "Disable non-FedRAMP-authorized services for the CUI OU (least functionality)" ;
    sysml:ownedRelationship [
        a sysml:SatisfyRequirementUsage ;
        sysml:satisfyingElement ce:Disable_NonFedRAMP_Services ;
        sysml:satisfiedRequirement cmmc:CM.L2-3.4.6 , cmmc:CM.L2-3.4.7
    ] ;
    cmmc:controlsSatisfied cmmc:CM.L2-3.4.6 , cmmc:CM.L2-3.4.7 ;
    cmmc:verificationMethod ce:oracle-restrict-service-usage .

# Terraform baseline configuration + inventory.
ce:Terraform_Baseline a sysml:PartUsage ;
    rdfs:label "Terraform baseline configuration + resource inventory (IaC)" ;
    sysml:ownedRelationship [
        a sysml:SatisfyRequirementUsage ;
        sysml:satisfyingElement ce:Terraform_Baseline ;
        sysml:satisfiedRequirement cmmc:CM.L2-3.4.1 , cmmc:CM.L2-3.4.2
    ] ;
    cmmc:controlsSatisfied cmmc:CM.L2-3.4.1 , cmmc:CM.L2-3.4.2 ;
    cmmc:verificationMethod ce:oracle-terraform-baseline .

# Cloud Monitoring alerting on security-relevant events.
ce:Monitoring_Alerting a sysml:PartUsage ;
    rdfs:label "Cloud Monitoring + Workspace Alert Center (security alert monitoring/response)" ;
    sysml:ownedRelationship [
        a sysml:SatisfyRequirementUsage ;
        sysml:satisfyingElement ce:Monitoring_Alerting ;
        sysml:satisfiedRequirement cmmc:SI.L2-3.14.3 , cmmc:SI.L2-3.14.6
    ] ;
    cmmc:controlsSatisfied cmmc:SI.L2-3.14.3 , cmmc:SI.L2-3.14.6 ;
    cmmc:verificationMethod ce:oracle-monitoring-alerts .

#################################################################
# Inherited module (verificationMethod is a LITERAL — NOT machine-provable)
#################################################################

# CSP-inherited physical protection. PE.L2-3.10.1/2 are marked cmmc:inherited
# in the catalog: satisfied-by-inheritance from Google's IL4 data-center
# controls (per the Google CMMC Customer Responsibility Matrix). There is no
# Factory oracle for a datacenter's physical security — it is MET-when-attested,
# so the verificationMethod is a manual/inherited literal, not an oracle IRI.
ce:CSP_Physical_Inheritance a sysml:PartUsage ;
    rdfs:label "CSP-inherited physical protection (Google IL4 data-center controls)" ;
    sysml:ownedRelationship [
        a sysml:SatisfyRequirementUsage ;
        sysml:satisfyingElement ce:CSP_Physical_Inheritance ;
        sysml:satisfiedRequirement cmmc:PE.L2-3.10.1 , cmmc:PE.L2-3.10.2
    ] ;
    cmmc:controlsSatisfied cmmc:PE.L2-3.10.1 , cmmc:PE.L2-3.10.2 ;
    cmmc:satisfiedByInheritance true ;
    cmmc:verificationMethod "inherited:google-workspace-crm" .

# --- Track A machine-verified modules (added by the coverage build-out) ---

# VPC segmentation + firewall + Cloud Armor: covers most SC family network
# controls. Config-check oracle asserts default-deny ingress, private CUI
# subnet, TLS 1.2+ enforcement, no split-tunnel, session termination, and
# authenticity protection over a GCP Compute API export.
ce:VPC_Segmentation a sysml:PartUsage ;
    rdfs:label "VPC network segmentation (subnetworks + firewalls + Cloud Armor)" ;
    sysml:ownedRelationship [
        a sysml:SatisfyRequirementUsage ;
        sysml:satisfyingElement ce:VPC_Segmentation ;
        sysml:satisfiedRequirement
            cmmc:SC.L2-3.13.3 , cmmc:SC.L2-3.13.4 , cmmc:SC.L2-3.13.5 ,
            cmmc:SC.L2-3.13.6 , cmmc:SC.L2-3.13.7 , cmmc:SC.L2-3.13.8 ,
            cmmc:SC.L2-3.13.9 , cmmc:SC.L2-3.13.15
    ] ;
    cmmc:controlsSatisfied
        cmmc:SC.L2-3.13.3 , cmmc:SC.L2-3.13.4 , cmmc:SC.L2-3.13.5 ,
        cmmc:SC.L2-3.13.6 , cmmc:SC.L2-3.13.7 , cmmc:SC.L2-3.13.8 ,
        cmmc:SC.L2-3.13.9 , cmmc:SC.L2-3.13.15 ;
    cmmc:verificationMethod ce:oracle-vpc-segmentation .

ce:EndpointVerification_CrowdStrike a sysml:PartUsage ;
    rdfs:label "CrowdStrike Falcon EDR — malware + endpoint integrity" ;
    sysml:ownedRelationship [
        a sysml:SatisfyRequirementUsage ;
        sysml:satisfyingElement ce:EndpointVerification_CrowdStrike ;
        sysml:satisfiedRequirement cmmc:SI.L2-3.14.2 , cmmc:SI.L2-3.14.4 , cmmc:SI.L2-3.14.7
    ] ;
    cmmc:controlsSatisfied cmmc:SI.L2-3.14.2 , cmmc:SI.L2-3.14.4 , cmmc:SI.L2-3.14.7 ;
    cmmc:verificationMethod ce:oracle-endpoint-edr .

ce:MDM_ChromeOS a sysml:PartUsage ;
    rdfs:label "Chrome Cloud Management + Endpoint Verification (MDM)" ;
    sysml:ownedRelationship [
        a sysml:SatisfyRequirementUsage ;
        sysml:satisfyingElement ce:MDM_ChromeOS ;
        sysml:satisfiedRequirement cmmc:AC.L2-3.1.16 , cmmc:AC.L2-3.1.17 , cmmc:AC.L2-3.1.18 , cmmc:AC.L2-3.1.19 , cmmc:MP.L2-3.8.7
    ] ;
    cmmc:controlsSatisfied cmmc:AC.L2-3.1.16 , cmmc:AC.L2-3.1.17 , cmmc:AC.L2-3.1.18 , cmmc:AC.L2-3.1.19 , cmmc:MP.L2-3.8.7 ;
    cmmc:verificationMethod ce:oracle-mdm-policy .

ce:SecurityCommandCenter a sysml:PartUsage ;
    rdfs:label "GCP Security Command Center — vulnerability management" ;
    sysml:ownedRelationship [
        a sysml:SatisfyRequirementUsage ;
        sysml:satisfyingElement ce:SecurityCommandCenter ;
        sysml:satisfiedRequirement cmmc:RA.L2-3.11.2 , cmmc:SI.L2-3.14.1 , cmmc:SI.L2-3.14.5
    ] ;
    cmmc:controlsSatisfied cmmc:RA.L2-3.11.2 , cmmc:SI.L2-3.14.1 , cmmc:SI.L2-3.14.5 ;
    cmmc:verificationMethod ce:oracle-scc-vuln-mgmt .

ce:WorkspaceAdmin_Policy a sysml:PartUsage ;
    rdfs:label "Workspace Admin identity lifecycle + password policy" ;
    sysml:ownedRelationship [
        a sysml:SatisfyRequirementUsage ;
        sysml:satisfyingElement ce:WorkspaceAdmin_Policy ;
        sysml:satisfiedRequirement cmmc:IA.L2-3.5.1 , cmmc:IA.L2-3.5.5 , cmmc:IA.L2-3.5.6 , cmmc:IA.L2-3.5.7 , cmmc:IA.L2-3.5.8 , cmmc:IA.L2-3.5.9 , cmmc:IA.L2-3.5.10 , cmmc:IA.L2-3.5.11
    ] ;
    cmmc:controlsSatisfied cmmc:IA.L2-3.5.1 , cmmc:IA.L2-3.5.5 , cmmc:IA.L2-3.5.6 , cmmc:IA.L2-3.5.7 , cmmc:IA.L2-3.5.8 , cmmc:IA.L2-3.5.9 , cmmc:IA.L2-3.5.10 , cmmc:IA.L2-3.5.11 ;
    cmmc:verificationMethod ce:oracle-workspace-admin-policy .

ce:VPNAccess_BeyondCorp a sysml:PartUsage ;
    rdfs:label "BeyondCorp Enterprise remote access + TLS enforcement" ;
    sysml:ownedRelationship [
        a sysml:SatisfyRequirementUsage ;
        sysml:satisfyingElement ce:VPNAccess_BeyondCorp ;
        sysml:satisfiedRequirement cmmc:AC.L2-3.1.12 , cmmc:AC.L2-3.1.13 , cmmc:AC.L2-3.1.14
    ] ;
    cmmc:controlsSatisfied cmmc:AC.L2-3.1.12 , cmmc:AC.L2-3.1.13 , cmmc:AC.L2-3.1.14 ;
    cmmc:verificationMethod ce:oracle-beyondcorp-remote-access .

ce:ChangeManagement_GitHub a sysml:PartUsage ;
    rdfs:label "GitHub branch protection + required reviews" ;
    sysml:ownedRelationship [
        a sysml:SatisfyRequirementUsage ;
        sysml:satisfyingElement ce:ChangeManagement_GitHub ;
        sysml:satisfiedRequirement cmmc:CM.L2-3.4.3 , cmmc:CM.L2-3.4.5
    ] ;
    cmmc:controlsSatisfied cmmc:CM.L2-3.4.3 , cmmc:CM.L2-3.4.5 ;
    cmmc:verificationMethod ce:oracle-github-change-mgmt .

ce:CloudIdentity_RemoteMaintenance a sysml:PartUsage ;
    rdfs:label "Cloud Identity MFA for ops / break-glass roles" ;
    sysml:ownedRelationship [
        a sysml:SatisfyRequirementUsage ;
        sysml:satisfyingElement ce:CloudIdentity_RemoteMaintenance ;
        sysml:satisfiedRequirement cmmc:MA.L2-3.7.5
    ] ;
    cmmc:controlsSatisfied cmmc:MA.L2-3.7.5 ;
    cmmc:verificationMethod ce:oracle-remote-maintenance-mfa .

ce:CloudLogging_Config a sysml:PartUsage ;
    rdfs:label "Cloud Logging sinks + NTP + IAM on log buckets" ;
    sysml:ownedRelationship [
        a sysml:SatisfyRequirementUsage ;
        sysml:satisfyingElement ce:CloudLogging_Config ;
        sysml:satisfiedRequirement cmmc:AU.L2-3.3.4 , cmmc:AU.L2-3.3.7 , cmmc:AU.L2-3.3.8 , cmmc:AU.L2-3.3.9
    ] ;
    cmmc:controlsSatisfied cmmc:AU.L2-3.3.4 , cmmc:AU.L2-3.3.7 , cmmc:AU.L2-3.3.8 , cmmc:AU.L2-3.3.9 ;
    cmmc:verificationMethod ce:oracle-cloud-logging-config .

ce:OrgPolicy_Allowlist a sysml:PartUsage ;
    rdfs:label "Binary Authorization — image allowlist / user-installed software" ;
    sysml:ownedRelationship [
        a sysml:SatisfyRequirementUsage ;
        sysml:satisfyingElement ce:OrgPolicy_Allowlist ;
        sysml:satisfiedRequirement cmmc:CM.L2-3.4.8 , cmmc:CM.L2-3.4.9
    ] ;
    cmmc:controlsSatisfied cmmc:CM.L2-3.4.8 , cmmc:CM.L2-3.4.9 ;
    cmmc:verificationMethod ce:oracle-binauth-allowlist .

ce:OrgPolicy_SessionControl a sysml:PartUsage ;
    rdfs:label "Cloud Identity session control + failed-login lockout" ;
    sysml:ownedRelationship [
        a sysml:SatisfyRequirementUsage ;
        sysml:satisfyingElement ce:OrgPolicy_SessionControl ;
        sysml:satisfiedRequirement cmmc:AC.L2-3.1.8 , cmmc:AC.L2-3.1.10 , cmmc:AC.L2-3.1.11
    ] ;
    cmmc:controlsSatisfied cmmc:AC.L2-3.1.8 , cmmc:AC.L2-3.1.10 , cmmc:AC.L2-3.1.11 ;
    cmmc:verificationMethod ce:oracle-session-control .

ce:AccessTransparency_ExternalSystems a sysml:PartUsage ;
    rdfs:label "VPC Service Controls perimeter — external system authorization" ;
    sysml:ownedRelationship [
        a sysml:SatisfyRequirementUsage ;
        sysml:satisfyingElement ce:AccessTransparency_ExternalSystems ;
        sysml:satisfiedRequirement cmmc:AC.L2-3.1.20
    ] ;
    cmmc:controlsSatisfied cmmc:AC.L2-3.1.20 ;
    cmmc:verificationMethod ce:oracle-vpc-sc-perimeter .

ce:IAMRoles_Privilege a sysml:PartUsage ;
    rdfs:label "GCP IAM policy + audit-log signals for privileged use" ;
    sysml:ownedRelationship [
        a sysml:SatisfyRequirementUsage ;
        sysml:satisfyingElement ce:IAMRoles_Privilege ;
        sysml:satisfiedRequirement cmmc:AC.L2-3.1.6 , cmmc:AC.L2-3.1.7
    ] ;
    cmmc:controlsSatisfied cmmc:AC.L2-3.1.6 , cmmc:AC.L2-3.1.7 ;
    cmmc:verificationMethod ce:oracle-iam-privileged-use .

#################################################################
# Track B — attested-reference (policy) modules.
#
# Each carries: ce:authoritativeSource (the system that owns the truth),
# ce:reference (into structural/references.ttl), ce:attestationRole (required
# signer role), and cmmc:verificationMethod ce:oracle-attested-reference.
#
# References are resolved and freshness-checked by
# oracles.attested_reference.evaluate_attested_reference; fixture AO signatures
# live in attestations/tier1.jsonl (evidentiary_status "attested-reference-mock").
#################################################################

ce:POL_SSP_SystemDescription a sysml:PartUsage ;
    rdfs:label "System Security Plan supplement (system description)" ;
    sysml:ownedRelationship [
        a sysml:SatisfyRequirementUsage ;
        sysml:satisfyingElement ce:POL_SSP_SystemDescription ;
        sysml:satisfiedRequirement cmmc:CA.L2-3.12.4
    ] ;
    cmmc:controlsSatisfied cmmc:CA.L2-3.12.4 ;
    ce:authoritativeSource ce:AUTHSRC_DocRepo ;
    ce:reference ce:REF_POL_SSP_v1 ;
    ce:attestationRole ce:Role_AffirmingOfficial ;
    cmmc:verificationMethod ce:oracle-attested-reference .

ce:POL_AT_Training a sysml:PartUsage ;
    rdfs:label "Annual security awareness + role-based training program" ;
    sysml:ownedRelationship [
        a sysml:SatisfyRequirementUsage ;
        sysml:satisfyingElement ce:POL_AT_Training ;
        sysml:satisfiedRequirement cmmc:AT.L2-3.2.1 , cmmc:AT.L2-3.2.2 , cmmc:AT.L2-3.2.3
    ] ;
    cmmc:controlsSatisfied cmmc:AT.L2-3.2.1 , cmmc:AT.L2-3.2.2 , cmmc:AT.L2-3.2.3 ;
    ce:authoritativeSource ce:AUTHSRC_LMS ;
    ce:reference ce:REF_POL_AT_Training_v1 ;
    ce:attestationRole ce:Role_SecurityOfficer ;
    cmmc:verificationMethod ce:oracle-attested-reference .

ce:POL_IR_Plan a sysml:PartUsage ;
    rdfs:label "Incident Response Plan + annual tabletop exercise" ;
    sysml:ownedRelationship [
        a sysml:SatisfyRequirementUsage ;
        sysml:satisfyingElement ce:POL_IR_Plan ;
        sysml:satisfiedRequirement cmmc:IR.L2-3.6.1 , cmmc:IR.L2-3.6.2 , cmmc:IR.L2-3.6.3
    ] ;
    cmmc:controlsSatisfied cmmc:IR.L2-3.6.1 , cmmc:IR.L2-3.6.2 , cmmc:IR.L2-3.6.3 ;
    ce:authoritativeSource ce:AUTHSRC_DocRepo ;
    ce:reference ce:REF_POL_IR_Plan_v1 ;
    ce:attestationRole ce:Role_SecurityOfficer ;
    cmmc:verificationMethod ce:oracle-attested-reference .

ce:POL_RA_Assessment a sysml:PartUsage ;
    rdfs:label "Formal risk assessment + finding tracker" ;
    sysml:ownedRelationship [
        a sysml:SatisfyRequirementUsage ;
        sysml:satisfyingElement ce:POL_RA_Assessment ;
        sysml:satisfiedRequirement cmmc:RA.L2-3.11.1 , cmmc:RA.L2-3.11.3
    ] ;
    cmmc:controlsSatisfied cmmc:RA.L2-3.11.1 , cmmc:RA.L2-3.11.3 ;
    ce:authoritativeSource ce:AUTHSRC_DocRepo ;
    ce:reference ce:REF_POL_RA_Assessment_v1 ;
    ce:attestationRole ce:Role_SecurityOfficer ;
    cmmc:verificationMethod ce:oracle-attested-reference .

ce:POL_PS_Personnel a sysml:PartUsage ;
    rdfs:label "Personnel security: background screening + offboarding" ;
    sysml:ownedRelationship [
        a sysml:SatisfyRequirementUsage ;
        sysml:satisfyingElement ce:POL_PS_Personnel ;
        sysml:satisfiedRequirement cmmc:PS.L2-3.9.1 , cmmc:PS.L2-3.9.2
    ] ;
    cmmc:controlsSatisfied cmmc:PS.L2-3.9.1 , cmmc:PS.L2-3.9.2 ;
    ce:authoritativeSource ce:AUTHSRC_HRIS ;
    ce:reference ce:REF_POL_PS_Personnel_v1 ;
    ce:attestationRole ce:Role_OPs ;
    cmmc:verificationMethod ce:oracle-attested-reference .

ce:POL_CM_Config a sysml:PartUsage ;
    rdfs:label "Configuration management: security impact analysis procedure" ;
    sysml:ownedRelationship [
        a sysml:SatisfyRequirementUsage ;
        sysml:satisfyingElement ce:POL_CM_Config ;
        sysml:satisfiedRequirement cmmc:CM.L2-3.4.4
    ] ;
    cmmc:controlsSatisfied cmmc:CM.L2-3.4.4 ;
    ce:authoritativeSource ce:AUTHSRC_DocRepo ;
    ce:reference ce:REF_POL_CM_Config_v1 ;
    ce:attestationRole ce:Role_ITAdmin ;
    cmmc:verificationMethod ce:oracle-attested-reference .

ce:POL_MA_Maintenance a sysml:PartUsage ;
    rdfs:label "Maintenance policy: approved vendor list + maintenance log" ;
    sysml:ownedRelationship [
        a sysml:SatisfyRequirementUsage ;
        sysml:satisfyingElement ce:POL_MA_Maintenance ;
        sysml:satisfiedRequirement cmmc:MA.L2-3.7.1 , cmmc:MA.L2-3.7.2 , cmmc:MA.L2-3.7.3 , cmmc:MA.L2-3.7.4 , cmmc:MA.L2-3.7.6
