    cmmc:controlsSatisfied cmmc:MA.L2-3.7.1 , cmmc:MA.L2-3.7.2 , cmmc:MA.L2-3.7.3 , cmmc:MA.L2-3.7.4 , cmmc:MA.L2-3.7.6 ;
    ce:authoritativeSource ce:AUTHSRC_DocRepo ;
