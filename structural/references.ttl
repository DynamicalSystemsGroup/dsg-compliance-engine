# Track B (attested-reference) sidecar — authoritative sources + references.
#
# Sidecar of ce:AuthoritativeSource and ce:Reference individuals cited by
# modules in structural/tier1.ttl. Kept separate so topology (tier1.ttl) stays
# stable while references churn (URIs move, freshness policies change, new
# authoritative systems come online). Loaded into the <ce:structural> named
# graph alongside tier1.ttl.
#
# Prefixes match ontology/prefixes.py exactly. Schema is defined in
# ontology/ce-attestation-refs.ttl (do not reintroduce class-level triples
# here).

@prefix ce:    <http://dynamicalsystems.group/compliance-engine/> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .

#################################################################
# Authoritative sources
#################################################################

# --- Track B (paperwork) ---

ce:AUTHSRC_DocRepo a ce:AuthoritativeSource ;
    rdfs:label "In-repo policy document store (documents/policies/)" ;
    rdfs:comment "File:// URIs into the git-tracked policy directory. Freshness is enforced by the reference's ce:lastVerified; substantive change is caught by git history." .

ce:AUTHSRC_LMS a ce:AuthoritativeSource ;
    rdfs:label "Learning Management System (KnowBe4 / Vector)" ;
    rdfs:comment "Training completion records. Reference URIs point at the report export for the current training cycle." .

ce:AUTHSRC_HRIS a ce:AuthoritativeSource ;
    rdfs:label "Human Resources Info System (Rippling / Gusto)" ;
    rdfs:comment "Personnel lifecycle records: background checks, hire/termination events, offboarding checklists." .

ce:AUTHSRC_TicketingSystem a ce:AuthoritativeSource ;
    rdfs:label "Ticketing system (Linear / Jira)" ;
    rdfs:comment "Operational event log: tabletop drill runs, maintenance events, sanitization records, offboarding tickets." .

ce:AUTHSRC_EngineHistory a ce:AuthoritativeSource ;
    rdfs:label "This compliance engine's own run history" ;
    rdfs:comment "The audit / evidence graphs produced by prior engine runs. Used for continuous-monitoring evidence (CA family)." .

# --- Track A (machine) ---

ce:AUTHSRC_GCP_ComputeAPI a ce:AuthoritativeSource ;
    rdfs:label "GCP Compute API" ;
    rdfs:comment "VPC networks, subnetworks, firewall rules, Cloud Armor policies." .

ce:AUTHSRC_GCP_CloudLogging a ce:AuthoritativeSource ;
    rdfs:label "GCP Cloud Logging API" ;
    rdfs:comment "Log sinks, retention policy, IAM on log buckets." .

ce:AUTHSRC_GCP_SCC a ce:AuthoritativeSource ;
    rdfs:label "GCP Security Command Center API" ;
    rdfs:comment "Vulnerability scan runs + findings." .

ce:AUTHSRC_GCP_BinaryAuth a ce:AuthoritativeSource ;
    rdfs:label "GCP Binary Authorization API" ;
    rdfs:comment "Container image allowlist / attestation policy." .

ce:AUTHSRC_GCP_IAM a ce:AuthoritativeSource ;
    rdfs:label "GCP IAM API + audit logs" ;
    rdfs:comment "Role bindings + privileged-action audit trail." .

ce:AUTHSRC_Workspace_AdminSDK a ce:AuthoritativeSource ;
    rdfs:label "Google Workspace Admin SDK" ;
    rdfs:comment "User/group/policy configuration for Workspace CUI users." .

ce:AUTHSRC_CrowdStrike a ce:AuthoritativeSource ;
    rdfs:label "CrowdStrike Falcon API" ;
    rdfs:comment "Endpoint sensor status + AV definition freshness + anomaly detection." .

ce:AUTHSRC_GCP_BeyondCorp a ce:AuthoritativeSource ;
    rdfs:label "GCP BeyondCorp Enterprise API" ;
    rdfs:comment "Zero-trust remote access policy + session config." .

ce:AUTHSRC_ChromeCloudMgmt a ce:AuthoritativeSource ;
    rdfs:label "Chrome Browser Cloud Management + Endpoint Verification" ;
    rdfs:comment "Managed device policy: 802.1X, encryption, USB, MDM." .

ce:AUTHSRC_GitHub_API a ce:AuthoritativeSource ;
    rdfs:label "GitHub REST API" ;
    rdfs:comment "Branch protection, required reviews, change log commits." .

ce:AUTHSRC_GCP_CloudIdentity a ce:AuthoritativeSource ;
    rdfs:label "GCP Cloud Identity policy" ;
    rdfs:comment "Session duration, idle timeout, failed-login lockout." .

ce:AUTHSRC_GCP_VPCServiceControls a ce:AuthoritativeSource ;
    rdfs:label "GCP VPC Service Controls" ;
    rdfs:comment "Service perimeter config + external-system authorization." .

#################################################################
# Track B references — one per policy module. lastVerified is a fixture
# timestamp; production runs update this via a resolver plugin per source.
#################################################################

ce:REF_POL_SSP_v1 a ce:Reference ;
    rdfs:label "SSP supplement (system description) v1" ;
    ce:uri <file://documents/policies/POL_SSP_SystemDescription.md> ;
    ce:sourceSystem ce:AUTHSRC_DocRepo ;
    ce:freshnessDays "365"^^xsd:integer ;
    ce:lastVerified "2026-06-15T12:00:00+00:00"^^xsd:dateTime ;
    ce:custodian "Sayer Tindall (Affirming Official)" .

