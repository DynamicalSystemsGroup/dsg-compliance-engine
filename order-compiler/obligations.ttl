# Contract Obligation Profile (COP) vocab + a worked NV012 example.
# Produced by the Order Compiler; AI-drafted, human-attested. Each obligation
# derives a required control set (Gate 1 resolves controls -> modules).
#
# Environment obligations (framework|hosting|data|personnel|environment) drive
# the Order. Deliverable obligations are TAGGED but NOT provisioned — UNLESS
# they carry a CUI/ITAR cmmc:dataMarker, in which case rule_library.resolve()
# raises a spillover-review flag rather than silently dropping an environment
# control (R11; see U4 guard).

@prefix cmmc: <http://dynamicalsystems.group/ontology/cmmc#> .
@prefix ce:   <http://dynamicalsystems.group/compliance-engine/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

#################################################################
# TBox
#################################################################
cmmc:Obligation a rdfs:Class ;
    rdfs:label "A contract-imposed obligation, extracted into the COP" .
cmmc:obligationType   a rdf:Property ;   # framework|hosting|data|personnel|environment|deliverable
    rdfs:comment "One of: framework, hosting, data, personnel, environment, deliverable." .
cmmc:sourceRef        a rdf:Property ;   # hashed clause / Q&A reference
    rdfs:comment "Content-addressed reference to the clause / Q&A that imposes the obligation." .
cmmc:derivesControls  a rdf:Property ;   # -> cmmc:Control(s) or an expansion token
    rdfs:comment "Required control(s), or an expansion token (ALL-110-NIST-800-171 / IL5-OVERLAY / TIER1-SCOPE) that rule_library expands." .
cmmc:attestedBy       a rdf:Property ;   # Compliance Officer who confirmed the COP
    rdfs:comment "Agent who attested the extracted COP (the one human call)." .
cmmc:dataMarker       a rdf:Property ;   # CUI | ITAR
    rdfs:comment "Data sensitivity marker (CUI|ITAR). On a deliverable obligation it triggers the spillover-review guard." .

#################################################################
# NV012 example COP (drives the Order). EXTRACTED, then ATTESTED.
#################################################################
ce:COP-NV012 a prov:Entity ;
    rdfs:label "Contract Obligation Profile — DLA26BZ03-NV012" ;
    cmmc:attestedBy ce:role-ComplianceOfficer ;
    prov:wasDerivedFrom ce:contract-NV012-topic , ce:contract-NV012-QA .

# --- environment obligations: these DRIVE the Order -------------------------

ce:OBL-CMMC-L2 a cmmc:Obligation ;
    cmmc:obligationType "framework" ;
    cmmc:sourceRef "NV012 Q36/Q42: CMMC Level 2 (Self-Attestation) prior to award; minimum for systems processing CUI" ;
    cmmc:derivesControls "ALL-110-NIST-800-171" .   # expands to all 110 via rule_library

ce:OBL-IL5 a cmmc:Obligation ;
    cmmc:obligationType "hosting" ;
    cmmc:sourceRef "NV012 Q53: production env requires DoD Impact Level 5+ (Phase II)" ;
    cmmc:derivesControls "IL5-OVERLAY" ;            # Phase I: resolves to {} (deferred to Tier 2)
    rdfs:comment "Phase I is offeror-hosted Tier 1 (IL4); IL5 overlay is deferred to Tier 2 — NOT an error." .

ce:OBL-ITAR a cmmc:Obligation ;
    cmmc:obligationType "personnel" ;
    cmmc:sourceRef "NV012 topic ITAR section; 22 CFR 120-130; Q44 end-to-end CUI boundary" ;
    cmmc:dataMarker "ITAR" ;
    cmmc:derivesControls cmmc:SC.L2-3.13.11 ;       # + US-person, residency, e2e markers (rule_library)
    rdfs:comment "US-person access only; US data residency; end-to-end CUI boundary across all connectors (Q44)." .

ce:OBL-CUI-BOUNDARY a cmmc:Obligation ;
    cmmc:obligationType "data" ;
    cmmc:sourceRef "NV012 Q30/Q36: vendor financial / EBS data is CUI; boundary maintained end-to-end (Q44)" ;
    cmmc:dataMarker "CUI" ;
    cmmc:derivesControls cmmc:AC.L2-3.1.1 , cmmc:AC.L2-3.1.3 , cmmc:SC.L2-3.13.8 , cmmc:SC.L2-3.13.16 .

ce:OBL-PHASE1-ENV a cmmc:Obligation ;
    cmmc:obligationType "environment" ;
    cmmc:sourceRef "NV012 Q53: offeror-hosted, CUI-compliant env; Q10: no live EBS API in Phase I" ;
    cmmc:derivesControls "TIER1-SCOPE" .            # scope marker, not a direct control

# --- deliverable obligations: TAGGED, not provisioned (out of Order scope) ---

ce:OBL-AUDIT-EVIDENCE a cmmc:Obligation ;
    cmmc:obligationType "deliverable" ;
    cmmc:sourceRef "NV012 Q7/Q46: audit-ready, explainable, traceable tool output" ;
    rdfs:comment "About the DELIVERABLE (SFFAS 47 tool), not DSG's compliance environment. No dataMarker -> resolves to {}." .

# A deliverable that TOUCHES CUI on DSG infra: must NOT silently drop to {}.
# rule_library.resolve() raises SpilloverReviewRequired for this obligation.
ce:OBL-VENDOR-PORTAL a cmmc:Obligation ;
    cmmc:obligationType "deliverable" ;
    cmmc:sourceRef "NV012 Q42/Q44: voluntary vendor self-reporting portal handling CUI" ;
    cmmc:dataMarker "CUI" ;
    rdfs:comment "Deliverable that ingests CUI on DSG infrastructure -> triggers env-spillover review (R11), not a silent {}." .
